# Supabase project settings. The anon key is used only for one-time signed browser uploads.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets. Never prefix these with NEXT_PUBLIC_ and never commit real values.
SUPABASE_SERVICE_ROLE_KEY=
WRITER_PASSCODE=
READER_PASSCODE=
SESSION_SECRET=

# Cloudflare R2 stores film enclosures at original quality. Uploads still use
# short-lived presigned PUT URLs generated from these server-only credentials.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_VIDEO_BUCKET=

# Enable the bucket's r2.dev development URL manually in the Cloudflare
# dashboard, then paste that public base URL here without a trailing slash.
R2_PUBLIC_BASE_URL=
